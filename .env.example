# ==========================================
# Shared environment variables (root)
# Copy to .env and adjust values for local dev
# ==========================================

# ---------- Postgres ----------
POSTGRES_USER=docprocessor
POSTGRES_PASSWORD=docprocessor_dev_pwd
POSTGRES_DB=document_processing
POSTGRES_PORT=5432

# ---------- Redis (BullMQ) ----------
REDIS_PORT=6379

# ---------- Backend ----------
BACKEND_PORT=3000
BACKEND_NODE_ENV=development
# URL the backend uses to connect to Postgres from inside docker
DATABASE_URL=postgresql://docprocessor:docprocessor_dev_pwd@postgres:5432/document_processing?schema=public
REDIS_HOST=redis
REDIS_URL=redis://redis:6379

# Concurrency limits for the worker pool
WORKER_CONCURRENCY=4
BATCH_SIZE=5

# Folder (inside the backend container) from where .txt files are loaded
DOCUMENTS_INPUT_DIR=/app/sample-data

# CORS origin for the frontend
CORS_ORIGIN=http://localhost:5173

# Log level (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# ---------- Frontend ----------
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

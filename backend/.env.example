# ==========================================
# Backend environment variables for LOCAL dev
# (outside Docker — used by Prisma CLI and `npm run start:dev`)
#
# Copy to backend/.env and adjust if needed.
# This file is read by Prisma CLI when it runs from this folder,
# and by NestJS ConfigModule when running locally.
#
# For Docker Compose execution, the backend container receives its
# environment from the root `.env` file (see docker-compose.yml),
# so this file is only relevant when running the backend directly
# on your host machine.
# ==========================================

NODE_ENV=development
PORT=3000

# Postgres must be reachable on localhost (e.g. via `docker compose up -d postgres`)
DATABASE_URL=postgresql://docprocessor:docprocessor_dev_pwd@localhost:5432/document_processing?schema=public

# Redis must be reachable on localhost (e.g. via `docker compose up -d redis`)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Processing
WORKER_CONCURRENCY=4
BATCH_SIZE=5

# Absolute or relative path from the backend cwd (backend/)
DOCUMENTS_INPUT_DIR=../sample-data

# CORS
CORS_ORIGIN=http://localhost:5173

# Log level
LOG_LEVEL=debug
